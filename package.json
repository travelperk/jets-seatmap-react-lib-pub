  "description": "Jets seatmap react library.",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns='src/.*\\.integration\\.test\\.js$'",
    "test:integration": "jest --testPathPattern='src/.*\\.integration\\.test\\.js$'",
    "test:coverage": "jest --coverage --coverageReporters=lcov --coverageReporters=text",
    "test:ci": "jest --ci --coverage --coverageReporters=text --verbose=false",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider start-storybook -p 6006",
    "build-storybook": "NODE_OPTIONS=--openssl-legacy-provider build-storybook",
    "build-lib": "rollup -c"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "react",
    "seatmap",
    "seat map",
    "seatmaps.com",
